{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "8a42fb13fa024d819e196b03777c7c03",
    "m_Title": "",
    "m_Content": "If you plug the result of this divide node into your output color, you can visualize what this optimization is doing. Areas where the result is white are doing the full number of steps while areas that are darker are doing fewer steps.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -363.0,
        "y": 1044.0,
